{
  "name": "rotion",
  "private": true,
  "description": "Blog turbo repo",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:prod": "turbo run build:prod",
    "check": "biome check",
    "check:fix": "biome check --write",
    "dev": "turbo run dev",
    "prepare": "husky"
  },
  "dependencies": {
    "turbo": "^2.8.10"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@commitlint/types": "^20.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*": [
      "biome check --write"
    ]
  }
}
